# Web transport:
# - server-action: run only the Next.js app with `bun run dev`
# - api: run Next.js + the Elysia API with `bun run dev:full`
NEXT_PUBLIC_POLYGON_TRANSPORT=server-action

# Image dimensions for polygon coordinate space.
IMAGE_WIDTH=1920
IMAGE_HEIGHT=1080

# API server URL used by Next.js rewrites when transport is `api`.
POLYGON_API_ORIGIN=http://localhost:3001

# Elysia API port.
PORT=3001

# SQLite database location for local development.
SQLITE_DB_PATH=./data/polygons.sqlite

# Optional artificial latency for create/delete/list actions.
POLYGON_ACTION_DELAY_MS=5000
