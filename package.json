{
  "name": "polygon-notraffic",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "packages/configs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev --filter=web",
    "dev:full": "turbo run dev --filter=web --filter=server",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "test": "turbo run test --",
    "test:coverage": "turbo run test -- all --coverage"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "turbo": "2.9.14",
    "typescript": "6.0.3"
  },
  "packageManager": "bun@1.3.14"
}